import random

def player_turn(current_number):
    valid_numbers = [current_number + i for i in range(1, 4)]
    while True:
        try:
            numbers = list(map(int, input("My turn - 숫자를 입력하세요: ").split()))
            if all(num in valid_numbers for num in numbers):
                return numbers[-1]
            else:
                print("유효한 숫자를 입력하세요.")
        except ValueError:
            print("숫자를 입력하세요.")

def computer_turn(current_number):
    computer_turn_num = random.randint(1, 3)
    return [current_number + i for i in range(1, computer_turn_num + 1)]

def bs31():
    current_number = 1
    print("베스킨라빈스 써리원 게임")
    print("------------------")

    while current_number < 31:
        player_numbers = player_turn(current_number)
        current_number = player_numbers + 1

        if current_number >= 31:
            print("플레이어 승리!")
            break

        print(f"현재 숫자 : {current_number}")

        computer_numbers = computer_turn(current_number)
        current_number = computer_numbers[-1] + 1

        if current_number >= 31:
            print("컴퓨터 승리!")
            break

        print(f"컴퓨터 : {computer_numbers}")
        print(f"현재 숫자 : {current_number}")

bs31()



