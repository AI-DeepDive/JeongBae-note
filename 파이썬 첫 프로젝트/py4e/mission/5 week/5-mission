def after_100(month, day, day_of_week):
    days_of_week = ["월", "화", "수", "목", "금", "토", "일"]
    days_in_month = [0, 31, 28, 31, 30, 31, 30, 31, 31, 30, 31, 30, 31]

    current_day_of_week = days_of_week.index(day_of_week)
    current_month = month
    current_day = day + 1

    for _ in range(100):
        current_day += 1

        if current_day > days_in_month[current_month]:
            current_day = 1
            current_month += 1
            if current_month > 12:
                current_month = 1

        current_day_of_week = (current_day_of_week + 1) % 7

    print(f"우리의 기념일은 {month}월 {day}일 {day_of_week}요일입니다.")
    print(f"이로부터 100일 뒤의 날짜는 {current_month}월 {current_day}일 {days_of_week[current_day_of_week]}요일입니다.")

