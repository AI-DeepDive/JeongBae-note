import random

def guess_numbers():
    answer = random.randint(0, 100)
    attempts = []

    print("Up&Down 게임을 시작합니다!")

    while True:
        guess = int(input("숫자를 예측해보세요 : "))

        if guess in attempts:
            print("이미 예측에 사용한 숫자입니다. 다시 한번 고민해보세요.")
        else:
            attempts.append(guess)

            if guess > answer:
                print("Down! 다시 한번 고민해보세요.")
            elif guess < answer:
                print("UP! 다시 한번 고민해보세요.")
            else:
                print(f"정답입니다. {len(attempts)}차 시도만에 예측에 성공했네요!! 게임을 종료합니다.")
                break

            if len(attempts) > 1:
                min_close = min(attempts, key=lambda x: abs(x - answer))
                max_close = max(attempts, key=lambda x: abs(x - answer))
                print(f"지금까지의 시도 중 정답에 가까운 최소값은 {min_close}입니다.")
                print(f"지금까지의 시도 중 정답에 가까운 최대값은 {max_close}입니다.")

guess_numbers()


