def grader(student_answers, answer_key):
    scores = []

    for student_info in student_answers:
        student_info = student_info.split(',')
        student_name = student_info[0]
        student_answer = student_info[1]

        total_score = 0
        for i in range(len(student_answer)):
            if int(student_answer[i]) == answer_key[i]:
                total_score += 10

        scores.append((student_name, total_score))

    scores.sort(key=lambda x: x[1], reverse=True)

    print("학생별 점수와 등수:")
    for i, (student_name, total_score) in enumerate(scores, start=1):
        print(f"학생: {student_name} 점수: {total_score}점 {i}등")


