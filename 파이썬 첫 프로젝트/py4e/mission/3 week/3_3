# 컴퓨터와 하는 가위바위보 게임(업그레이드 버전)
# 몇 판을 진행할 지와 가위바위보 후, 최종 전적까지 알려줌.

import random #파이썬의 내장된 랜덤 기능을 사용할 수 있게 해줌.

def rsp_advanced(games):
    options = ["scissor", "rock", "paper"]

    user_wins = 0
    computer_wins = 0
    draws = 0

    for game in range(1, games + 1):
        print(f"\n판 수 : {game}")
        user_input = input("scissor, rock, paper 중에서 선택하세요: ")

        while user_input not in options and user_input not in ["0", "1", "2"]:
            print("잘못된 입력입니다. scissor, rock, paper 중에서 선택하세요.")
            user_input = input("scissor, rock, paper 중에서 선택하세요: ")

        if user_input in ["0", "1", "2"]:
            user_choice = options[int(user_input)]
        else:
            user_choice = user_input

        computer_choice = random.choice(options)
        print(f"나: {user_choice}")
        print(f"컴퓨터: {computer_choice}")

        if user_choice == computer_choice:
            print("비겼습니다!")
            draws += 1
        elif (user_choice == "scissor" and computer_choice == "paper") or \
             (user_choice == "rock" and computer_choice == "scissor") or \
             (user_choice == "paper" and computer_choice == "rock"):
            print("나의 승리!")
            user_wins += 1
        else:
            print("컴퓨터의 승리!")
            computer_wins += 1

    print(f"\n나의 전적: {user_wins}승 {draws}무 {computer_wins}패")
    print(f"컴퓨터의 전적: {computer_wins}승 {draws}무 {user_wins}패")

# 사용자로부터 게임 진행 횟수 입력받기
games = int(input("몇 판을 진행하시겠습니까? : "))
rsp_advanced(games)