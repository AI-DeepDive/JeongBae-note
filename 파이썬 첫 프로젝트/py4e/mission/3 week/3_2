# 구구단을 호출하는 프로그램
#조건 1: 홀 수 번째만 출력하기
#조건 2: 값이 50이하인 것만 출력하기

def gugudan(number):
    print(f"{number} 단")   #f는 f-string이라는 기능을 이용하여 이전에 사용하던 format을 대체한것
    for i in range(1, 10, 2):  # range의 첫 번째와 두 번째 매개변수는 시작과 끝을 의미함 
        result = number * i
        if result <= 50:  # 값이 50이하인 것만 출력하기 위해 조건문을 추가
            print(f"{number} X {i} = {result}")

# 사용자로부터 숫자 입력 받기
number = int(input("구구단 - 몇 단을 원하나요? : "))
gugudan(number)