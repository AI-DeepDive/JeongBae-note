# 두 수 사이의 소수의 갯수를 구하는 프로그램

def is_prime(num):
    if num < 2:
        return False
    for i in range(2, int(num ** 0.5) + 1):
        if num % i == 0:
            return False
    return True

def count_prime_number(n, m):
    prime_count = 0
    for num in range(n, m + 1):
        if is_prime(num):
            prime_count += 1

    print(f"소수개수: {prime_count}")

# 사용자로부터 두 숫자 입력받기
n = int(input("첫 번째 수 입력 : "))
m = int(input("두 번째 수 입력 : "))
count_prime_number(n, m)