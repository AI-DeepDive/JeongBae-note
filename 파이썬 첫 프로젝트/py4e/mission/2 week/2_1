#미션 1번 - 학점 변환 및 출력장치

def grade_convert(score):
    score =int (score)
    if score >= 95:
        grade = 'A+'
    elif score >= 90:
        grade = 'A'
    elif score >= 85:
        grade = 'B+'
    elif score >= 80:
        grade = 'B'
    elif score >= 75:
        grade = 'C+'
    elif score >= 70:
        grade = 'C'
    elif score >= 65:
        grade = 'D+'
    elif score >= 60:
        grade = 'D'
    else:
        grade = 'F'
    return grade

your_name = input("Enter your name :")
your_score = input("Enter your score:")

grade = grade_convert(your_score)
#입력받은 점수를 함수에 입력시켜 받은 변환값을 grade로 받음

print(your_name)
print("your score is", your_score)
print("your grade is", grade)

