def stock_profit(stocks, sells):
    stock_info = stocks.split(',')
    stock_data = []

    # Parse stock information and calculate profit
    for stock in stock_info:
        name, quantity, buy_price = stock.split('/')
        quantity = int(quantity)
        buy_price = int(buy_price)
        sell_price = sells.pop(0)  # Pop the first sell price for the current stock
        profit = ((sell_price - buy_price) / buy_price) * 100
        stock_data.append((name, profit))

    # Sort stock data based on profit in descending order
    stock_data.sort(key=lambda x: x[1], reverse=True)

    # Print stock profits
    for name, profit in stock_data:
        print(f"{name}의 수익률 {profit:.2f}")


# Call the function to calculate and print stock profits
stock_profit(stocks, sells)

