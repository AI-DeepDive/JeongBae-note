def sales_management(member_names, member_records):
    # Calculate average scores for each member
    average_scores = [sum(record) / len(record) for record in member_records]
    
    # Create a list of (name, average_score) tuples
    member_info = list(zip(member_names, average_scores))
    
    # Sort the list based on average scores in descending order
    member_info.sort(key=lambda x: x[1], reverse=True)
    
    bonus_target = []
    talk_target = []

    for i, (name, score) in enumerate(member_info):
        if i < 2:  # Top 2 members are bonus targets
            if score > 5:  # Exclude if average score is not greater than 5
                bonus_target.append(name)
        elif i >= 4:  # Bottom 2 members are talk targets
            if score <= 3:  # Exclude if average score is greater than 3
                talk_target.append(name)

    # Print bonus and talk targets
    print("보너스 대상자", ', '.join(bonus_target))
    print("면담 대상자", ', '.join(talk_target))


# Call the function to manage sales
sales_management(member_names, member_records)

