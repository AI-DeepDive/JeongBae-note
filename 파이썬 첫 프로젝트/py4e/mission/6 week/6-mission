def good_customer(info):
    info_list = info.split(',')
    members = []

    for i in range(0, len(info_list), 6):
        id_, age, phone, gender, location, purchase_count = info_list[i:i + 6]

        if phone == 'x':
            phone = "000-0000-0000"

        members.append({
            '아이디': id_,
            '나이': age,
            '전화번호': phone,
            '성별': gender,
            '지역': location,
            '구매횟수': int(purchase_count)
        })

    vip_members = []
    for member in members:
        if member['구매횟수'] >= 8 and member['전화번호'] != "000-0000-0000":
            vip_members.append(member)

    # Print all member info
    print(vip_members)

    # Print VIP member info for coupon
    for vip_member in vip_members:
        print("할인 쿠폰을 받을 회원정보", end=" ")
        for key, value in vip_member.items():
            print(f"{key}:{value}", end=", ")
        print()

# Call the function to find and print VIP members
good_customer(info)